# Files matching conf.exs pattern contain sensitive data and you
# should not commit them into version control.
#
# Alternatively, you may comment the line below and commit the
# secrets file. You can `git update-index --skip-worktree` to make git
# ignore this file (however sometimes this causes problems with bors trying to
# merge files)
#/config/runtime.exs

# Ignore digested assets cache
priv/static/cache_manifest.json

